# Flask
SECRET_KEY=replace-with-a-long-random-value
HOST=0.0.0.0
PORT=5000
DEBUG=false

# Auth seed, created only when the users table is empty
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Inference
DEVICE=auto
VEHICLE_MODEL=models/yolo/yolov8n.pt
EMERGENCY_MODEL=models/yolo/emergency/best.pt
VEHICLE_CONF=0.35
EMERGENCY_CONF=0.40
INFER_IMGSZ=640

# Traffic calibration
SATURATION_COUNT=40
FORECAST_INTERVAL_MIN=1
SEQUENCE_LENGTH=20
